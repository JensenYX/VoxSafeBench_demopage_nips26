\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces Discriminative unsafe-detection accuracy (Acc $\uparrow $, \%), reported as \textit  {EN\,/\,ZH}. \raisebox  {0.15ex}{\textcolor {fairHdr}{\rule  {0.85ex}{0.85ex}}}\,Text columns evaluate the pure-text modality. \raisebox  {0.15ex}{\textcolor {safetyHdr}{\rule  {0.85ex}{0.85ex}}}\,Audio columns evaluate clean/diverse audio (No Jailbreak) and jailbreak audio (Single-turn). Since all discriminative samples are unsafe by construction, Acc corresponds to the recall of predicting \texttt  {Yes} among non-skipped cases. ``Skipped'' outputs (non-parsable \texttt  {Yes/No} or API/pipeline errors) are excluded from the accuracy denominator. \textbf  {Bold}: column best per language; ``---'': modality not supported; $^\dagger $: thinking variant.}}{28}{table.caption.51}\protected@file@percent }
