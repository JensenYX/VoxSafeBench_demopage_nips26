\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {(a) Interactional privacy:} Precision--recall (English/Chinese); contours show F1 and marker size encodes accuracy (0.50 $\approx $ random guessing). \textbf  {(b) Inferential privacy:} Refusal-to-Answer (RtA) vs. inference accuracy (ACC) on five sensitive attributes from HearSay~\cite  {wang2026hearsay}. Error bars denote standard deviation; safer models lie in the bottom-right region (high RtA, low ACC).}}{7}{figure.caption.12}\protected@file@percent }
